# KeyboardTester.click — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.

# ── FTP Deployment ────────────────────────────────────────────────────────────
# Your hosting provider's FTP details (found in cPanel → FTP Accounts)
FTP_SERVER=ftp.yourdomain.com
FTP_USER=youruser@yourdomain.com
FTP_PASS=your_ftp_password_here
FTP_PATH=/

# ── Bing Webmaster API ────────────────────────────────────────────────────────
# Get from: https://www.bing.com/webmasters → Settings → API Access → Generate Key
BING_API_KEY=your_bing_api_key_here

# ── Google Indexing API ───────────────────────────────────────────────────────
# Place your service account JSON key as: google-credentials.json
# See submit-google-indexing.py for full setup instructions.

# ── IndexNow ─────────────────────────────────────────────────────────────────
# Generate a key at https://www.indexnow.org/
# Then create a file named <your-key>.txt in the site root with just the key as content.
# Update submit-indexnow.php with your key.
INDEXNOW_KEY=your_indexnow_key_here
