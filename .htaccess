# Serve .xml and .shtml files correctly
AddType application/xml .xml
AddType text/html .shtml
AddHandler server-parsed .shtml
Options +Includes
AddType image/webp .webp
AddType image/avif .avif

RewriteEngine On
RewriteBase /

# Serve robots.txt and ads.txt directly (bypass all rewrites)
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^ads\.txt$ - [L]

# Local-only/API endpoints that should never be indexed directly
RewriteRule ^ai-config\.php$ - [F,L]
RewriteRule ^testpage\.php$ - [R=410,L]

# ============================================
# CANONICAL URL ENFORCEMENT
# Force: HTTPS + non-www (keyboardtester.click)
# ============================================

# 1. Force HTTPS (redirect all HTTP to HTTPS)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2. Force non-www (redirect www to non-www)
RewriteCond %{HTTP_HOST} ^www\.keyboardtester\.click$ [NC]
RewriteRule ^ https://keyboardtester.click%{REQUEST_URI} [R=301,L]

# ============================================

# Canonical entry points and legacy aliases
RewriteRule ^index\.(php|html)$ / [R=301,L]
RewriteRule ^(languages/(arabic|russian|spanish|french|german|portuguese|japanese|korean))/index\.(php|html)$ /$1/ [R=301,L]
RewriteRule ^languages/(arabic|russian|spanish|french|german|portuguese|japanese|korean)/dead-pixel-test\.php$ /languages/$1/screen-test.php [R=301,L]
RewriteRule ^about\.php$ /about-us.php [R=301,L]
RewriteRule ^privacy\.php$ /privacy-policy.php [R=301,L]
RewriteRule ^contact\.php$ /feedback.php [R=301,L]
RewriteRule ^sitemap-index\.xml$ /sitemap.xml [R=301,L]

# ─── Strip trailing slash from .php URLs (prevents GSC duplicate-content) ───
RewriteCond %{REQUEST_METHOD} ^GET$
RewriteRule ^(.+)\.php/$ /$1.php [R=301,L]

# ─── Legacy ?lang=xx on /pages/all-tools.php → per-locale files ───
# (split-URL pattern for SEO; clean 301 so bots consolidate to new URLs)
RewriteCond %{QUERY_STRING} (^|&)lang=es(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-es.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=fr(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-fr.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=de(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-de.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=pt(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-pt.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=ar(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-ar.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=ru(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-ru.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=ja(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-ja.php? [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)lang=ko(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools-ko.php? [R=301,L]
# ?lang=en → strip the param (en is the canonical URL with no suffix)
RewriteCond %{QUERY_STRING} (^|&)lang=en(&|$)
RewriteRule ^pages/all-tools\.php$ /pages/all-tools.php? [R=301,L]

# Serve WebP when supported and available
RewriteCond %{HTTP_ACCEPT} image/webp
RewriteCond %{REQUEST_FILENAME} \.(png|jpe?g)$
RewriteCond %{REQUEST_FILENAME}.webp -f
RewriteRule ^(.+)\.(png|jpe?g)$ $1.$2.webp [T=image/webp,E=WEBP:1,L]

# Redirect old keyboard tester URLs to new organized structure
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^keyboard_tester_english\.(php|html)$ /tools/keyboard-tester/ [R=301,L]
RewriteRule ^keyboard-tester/?$ /tools/keyboard-tester/ [R=301,L]
RewriteRule ^keyboard-tester\.(php|html)$ /tools/keyboard-tester/ [R=301,L]
RewriteRule ^keyboard_tester_arabic\.(php|html)$ /languages/arabic/ [R=301,L]
RewriteRule ^keyboard_tester_russian\.(php|html)$ /languages/russian/ [R=301,L]
RewriteRule ^keyboard_tester_spanish\.(php|html)$ /languages/spanish/ [R=301,L]
RewriteRule ^keyboard_tester_french\.(php|html)$ /languages/french/ [R=301,L]
RewriteRule ^keyboard_tester_portuguese\.(php|html)$ /languages/portuguese/ [R=301,L]
RewriteRule ^keyboard_tester_japanese\.(php|html)$ /languages/japanese/ [R=301,L]
RewriteRule ^keyboard_tester_german\.(php|html)$ /languages/german/ [R=301,L]
RewriteRule ^keyboard_tester_korean_index\.(php|html)$ /languages/korean/ [R=301,L]

# Redirect old tool URLs to current versions  
RewriteRule ^keyboard-typing-test\.php$ /keyboard_typing_test.php [R=301,L]
RewriteRule ^mouse-speed-tester\.php$ /mouse_speed_tester.php [R=301,L]
RewriteRule ^mouse-sensitivity-dpi-tester\.php$ /mouse_sensitivity_DPI_tester.php [R=301,L]
RewriteRule ^screen-tester\.php$ /screentestindex.php [R=301,L]
RewriteRule ^webcam-tester\.php$ /webcamtesterindex.php [R=301,L]
RewriteRule ^qr-code-generator\.php$ /QR_code_generator_scanner.php [R=301,L]
RewriteRule ^whatsapp-brand-link-generator\.php$ /whatsapp-Brand-link-generator.php [R=301,L]
RewriteRule ^headphone-speaker-tester\.php$ /headphone_speaker_tester_index.php [R=301,L]
RewriteRule ^click-speed-test\.php$ /mouse_speed_tester.php [R=301,L]

# Legacy aliases still emitted by older localized/hreflang markup
RewriteRule ^dpi-tester\.php$ /mouse_sensitivity_DPI_tester.php [R=301,L]
RewriteRule ^ghost-click-test\.php$ /ghost-click-detector.php [R=301,L]
RewriteRule ^headphone-test\.php$ /headphone_speaker_tester_index.php [R=301,L]
RewriteRule ^mic-test\.php$ /mic-tester.php [R=301,L]
RewriteRule ^password-generator\.php$ /auto-password-generator.php [R=301,L]
RewriteRule ^qr-generator\.php$ /QR_code_generator_scanner.php [R=301,L]
RewriteRule ^qr-reader\.php$ /qr-code-reader.php [R=301,L]
RewriteRule ^screen-test\.php$ /screentestindex.php [R=301,L]
RewriteRule ^tools/headphone_speaker_tester\.php$ /headphone_speaker_tester_index.php [R=301,L]
RewriteRule ^tools/latency_checker\.php$ /latency-checker.php [R=301,L]
RewriteRule ^tools/password_generator\.php$ /auto-password-generator.php [R=301,L]
RewriteRule ^webcam-test\.php$ /webcamtesterindex.php [R=301,L]

# Assets fix - redirect wrong paths to correct ones
RewriteRule ^tools/assets/(.*)$ /assets/$1 [R=301,L]

# Favicon fallback: serve navigation.png for /favicon.ico
RewriteCond %{REQUEST_URI} ^/favicon\.ico$
RewriteRule ^favicon\.ico$ /navigation.png [L]

# Fallback: If .html file doesn't exist, serve .php version with same name
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} \.html$
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^(.*)\.html$ /$1.php [QSA,R=301,L]

# ============================================
# GZIP COMPRESSION - Reduces file sizes by 70%
# ============================================
<IfModule mod_deflate.c>
    # Compress HTML, CSS, JavaScript, Text, XML and fonts
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE image/x-icon
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject

    # Remove browser bugs
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary User-Agent
</IfModule>

# Fallback for servers without mod_deflate
<IfModule mod_gzip.c>
    mod_gzip_on Yes
    mod_gzip_dechunk Yes
    mod_gzip_item_include file \.(html?|txt|css|js|php|pl)$
    mod_gzip_item_include handler ^cgi-script$
    mod_gzip_item_include mime ^text/.*
    mod_gzip_item_include mime ^application/x-javascript.*
    mod_gzip_item_exclude mime ^image/.*
    mod_gzip_item_exclude rspheader ^Content-Encoding:.*gzip.*
</IfModule>

# ============================================
# BROWSER CACHING - Expires Headers
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Default expiration: 1 week
    ExpiresDefault "access plus 1 week"

    # HTML - short browser cache only (private, never proxy/nginx cached)
    ExpiresByType text/html "access plus 1 hour"

    # CSS and JavaScript - 1 year (use versioning for updates)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Images - 1 year
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/ico "access plus 1 year"

    # Fonts - 1 year
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

    # Data files
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType text/xml "access plus 0 seconds"

    # Manifest files
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType text/cache-manifest "access plus 0 seconds"
</IfModule>

# ============================================
# CACHE-CONTROL HEADERS (More specific control)
# ============================================
<IfModule mod_headers.c>
    # Security headers
    Header unset X-Powered-By
    Header always unset X-Powered-By
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy (CSP) - Prevents XSS attacks
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://*.clarity.ms https://www.clarity.ms https://www.googletagmanager.com https://www.google-analytics.com https://pagead2.googlesyndication.com https://adservice.google.com https://www.googleadservices.com https://tpc.googlesyndication.com https://ep1.adtrafficquality.google https://ep2.adtrafficquality.google https://fundingchoicesmessages.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' data: https: blob:; connect-src 'self' https://cdn.jsdelivr.net https://*.clarity.ms https://www.clarity.ms https://www.google-analytics.com https://*.google-analytics.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://fundingchoicesmessages.google.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://www.google.com https://ep1.adtrafficquality.google https://ep2.adtrafficquality.google https://fundingchoicesmessages.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"

    # Vary headers for proper caching
    Header append Vary "Accept-Encoding"
    Header append Vary "Accept" env=WEBP

    # DEFAULT: all responses are private / uncacheable by nginx/proxies.
    # X-Accel-Expires: 0 is the nginx-specific signal to never cache this response.
    # This catches extensionless URLs like / (served via DirectoryIndex index.php)
    # which FilesMatch "\.(php)$" would miss.
    Header always set Cache-Control "private, max-age=3600, must-revalidate"
    Header always set X-Accel-Expires "0"

    # Static assets — override the default above with long public cache
    <FilesMatch "\.(css|js|mjs)$">
        Header always set Cache-Control "public, max-age=31536000, immutable"
        Header always unset X-Accel-Expires
    </FilesMatch>

    # Images - immutable, 1 year cache
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|avif|svg|ico)$">
        Header always set Cache-Control "public, max-age=31536000, immutable"
        Header always unset X-Accel-Expires
    </FilesMatch>

    # Fonts - immutable, 1 year cache
    <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
        Header always set Cache-Control "public, max-age=31536000, immutable"
        Header always set Access-Control-Allow-Origin "*"
        Header always unset X-Accel-Expires
    </FilesMatch>

    # JSON - no cache (dynamic data)
    <FilesMatch "\.json$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Sitemap XML - allow caching and proper fetching
    <FilesMatch "sitemap.*\.xml$">
        Header set Cache-Control "public, max-age=86400"
        Header set Content-Type "application/xml; charset=utf-8"
        Header unset Content-Security-Policy
        Header unset X-Frame-Options
        Header unset X-Content-Type-Options
    </FilesMatch>

    # ads.txt - plain text (Google AdSense)
    <FilesMatch "ads\.txt$">
        Header set Cache-Control "public, max-age=86400"
        Header set Content-Type "text/plain; charset=utf-8"
        Header unset Content-Security-Policy
    </FilesMatch>

    # Robots.txt - plain text
    <FilesMatch "robots\.txt$">
        Header set Cache-Control "public, max-age=86400"
        Header set Content-Type "text/plain; charset=utf-8"
        Header unset Content-Security-Policy
        Header unset X-Frame-Options
        Header unset X-Content-Type-Options
    </FilesMatch>
</IfModule>

# Return 410 Gone for stale WordPress feed/tag/category URLs from when blog
# was at /blogs/. These never resolve in the current static blog and Google
# was reporting them as "Crawled - currently not indexed". 410 = strong drop signal.
RewriteRule ^blog(s)?/(tag|category|feed|comments|wp-content|wp-admin|wp-login|wp-includes|author|page)(/.*)?$ - [R=410,L]
RewriteRule ^blog(s)?/.+/feed/?$ - [R=410,L]

# /blogs/ → /blog/ (WordPress removed, replaced with static blog)
RewriteRule ^blogs(/.*)?$ /blog$1 [R=301,L]

# Lucky Wheel canonical redirect (luckywheeltoolindex.php is the main entry point)
RewriteRule ^lucky-wheel\.php$ /luckywheeltoolindex.php [R=301,L]
RewriteRule ^lucky-wheel-tool\.php$ /luckywheeltoolindex.php [R=301,L]

# Common legacy URL patterns that may cause 4xx in Bing crawl logs
RewriteRule ^screen-test-online\.php$ /screentestindex.php [R=301,L]
RewriteRule ^webcam-tester-online\.php$ /webcamtesterindex.php [R=301,L]
RewriteRule ^free-keyboard-tester\.php$ / [R=301,L]
RewriteRule ^keyboard-test\.php$ / [R=301,L]

# Explicit HTML→PHP redirects for pages already indexed under .html URLs
Redirect 301 /latency-checker.html /latency-checker.php

# Block direct indexing of tool partials (HTML fragments without <html> shell)
# These are included by parent pages; if Google finds them via accident, noindex.
# FilesMatch matches direct URL requests only — PHP includes are unaffected.
<IfModule mod_headers.c>
    <FilesMatch "^(screentesttool|webcamtestertool|headphone_speaker_tester_tool|luckywheeltool)\.php$">
        Header set X-Robots-Tag "noindex, nofollow"
    </FilesMatch>
</IfModule>

# Legacy duplicate redirect: mouse-trail-index.php → mouse-trail.php
# (PHP file does the 301; this is a belt-and-suspenders fallback)
RewriteRule ^mouse-trail-index\.php$ /mouse-trail.php [R=301,L]

# Custom 404 page
ErrorDocument 404 /404.php
